---
import Layout from "../components/Layout.astro";
import CtaSection from "../components/CtaSection.astro";
---

<Layout title="About Practice Buddy - Music Practice Made Simple">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div class="relative overflow-hidden bg-gradient-to-br bg-musical-primary">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-32 pb-10 md:pb-16">
        <div class="text-center">
          <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold text-white mb-4 md:mb-6">
            About <span class="text-musical-secondary">Practice Buddy</span>
          </h1>
          <p
            class="text-lg md:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed px-2"
          >
            Revolutionizing music education through smart practice tracking,
            personalized goals, and seamless teacher-student collaboration.
          </p>
        </div>
      </div>
    </div>

    <!-- Mission Section -->
    <div class="py-10 md:py-16">
      <div class="container max-w-7xl mx-auto px-4">
        <div class="text-center mb-10 md:mb-16">
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-musical-graphite mb-4 md:mb-6">
            Our Mission
          </h2>
          <p class="text-base md:text-lg text-musical-graphite/80 max-w-4xl mx-auto">
            Practice Buddy was created to bridge the gap between music lessons
            and home practice. We believe that consistent, focused practice is
            the key to musical growth, and we're here to make that journey
            engaging, trackable, and rewarding.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-8">
          <div class="card text-center">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
            >
              <svg
                class="w-8 h-8 text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <rect x="3" y="10" width="4" height="10" rx="1"></rect>
                <rect x="10" y="6" width="4" height="14" rx="1"></rect>
                <rect x="17" y="2" width="4" height="18" rx="1"></rect>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Track Progress
            </h3>
            <p class="text-musical-graphite/70">
              Monitor practice sessions, track goals, and visualize musical
              growth over time. Students can track their progress via the
              dashboard.
            </p>
          </div>

          <div class="card text-center">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-secondary to-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-yellow-600"
            >
              <svg
                class="w-8 h-8 text-musical-graphite"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
                <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3"></path>
                <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Personalized Learning
            </h3>
            <p class="text-musical-graphite/70">
              Custom assignments and goals tailored to each student's skill
              level and interests.
            </p>
          </div>

          <div class="card text-center">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-purple to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-purple-600"
            >
              <svg
                class="w-8 h-8 text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="7" r="4"></circle>
                <path d="M6 21v-2a6 6 0 0 1 12 0v2"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Teacher-Student Collaboration
            </h3>
            <p class="text-musical-graphite/70">
              Seamless communication between teachers and students for better
              learning outcomes.
            </p>
          </div>
        </div>

      

        <!-- How It Works Section -->
        <div class="py-10 md:py-16">
          <div class="container max-w-7xl mx-auto">
            <div class="text-center mb-10 md:mb-16">
              <h2
                class="text-2xl sm:text-3xl md:text-4xl font-bold text-musical-graphite mb-4 md:mb-6"
              >
                How It Works
              </h2>
              <p class="text-base md:text-lg text-musical-graphite/80 max-w-3xl mx-auto">
                Getting started with Practice Buddy is simple and
                straightforward.
              </p>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
              <div class="card text-center">
                <div
                  class="w-20 h-20 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
                >
                  1
                </div>
                <h3 class="text-xl font-semibold text-musical-graphite mb-2">
                  Sign Up
                </h3>
                <p class="text-musical-graphite/70">
                  Teachers and students create accounts to get started with the
                  platform.
                </p>
              </div>

              <div class="card text-center">
                <div
                  class="w-20 h-20 bg-gradient-to-br from-musical-secondary to-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 text-musical-graphite text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-yellow-600"
                >
                  2
                </div>
                <h3 class="text-xl font-semibold text-musical-graphite mb-2">
                  Set Up and Join Classes
                </h3>
                <p class="text-musical-graphite/70">
                  Teachers create classes and invite students to join their
                  musical community. Students join classes via a unique class
                  code. A class can be as small as a series of private lessons
                  or a big group lesson.
                </p>
              </div>

              <div class="card text-center">
                <div
                  class="w-20 h-20 bg-gradient-to-br from-musical-purple to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-purple-600"
                >
                  3
                </div>
                <h3 class="text-xl font-semibold text-musical-graphite mb-2">
                  Create Goals
                </h3>
                <p class="text-musical-graphite/70">
                  Teachers or parents can set personalized practice goals and
                  assignments for each student.
                </p>
              </div>

              <div class="card text-center">
                <div
                  class="w-20 h-20 bg-gradient-to-br from-musical-coral to-orange-400 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-orange-600"
                >
                  4
                </div>
                <h3 class="text-xl font-semibold text-musical-graphite mb-2">
                  Track Progress
                </h3>
                <p class="text-musical-graphite/70">
                  Both students and teachers can monitor practice sessions and
                  celebrate achievements together.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Video Section -->
    <div class="py-10 md:py-16 bg-gradient-to-br from-gray-50 to-gray-100">
      <div class="container max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8 md:mb-12">
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-musical-graphite mb-3 md:mb-4">
            See Practice Buddy in Action
          </h2>
          <p class="text-base md:text-lg text-musical-graphite/80 max-w-3xl mx-auto">
            Watch how Practice Buddy helps students and teachers work together to achieve musical goals.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 max-w-6xl mx-auto">
          <!-- Student Video -->
          <div class="card">
            <div class="mb-4">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">
                For Students
              </h3>
              <p class="text-musical-graphite/70 text-sm">
                Learn how students track practice, complete assignments, and earn stickers from their teachers.
              </p>
            </div>
            <div class="relative w-full rounded-lg overflow-hidden shadow-lg bg-black">
              <video
                class="w-full h-auto"
                controls
                preload="metadata"
                poster=""
              >
                <source src="/pb-students.mp4" type="video/mp4" />
                Your browser does not support the video tag.
              </video>
            </div>
          </div>

          <!-- Teacher Video -->
          <div class="card">
            <div class="mb-4">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">
                For Teachers
              </h3>
              <p class="text-musical-graphite/70 text-sm">
                Discover how teachers create classes, assign goals, and provide feedback to students.
              </p>
            </div>
            <div class="relative w-full rounded-lg overflow-hidden shadow-lg bg-black">
              <video
                class="w-full h-auto"
                controls
                preload="metadata"
                poster=""
              >
                <source src="/pb-teachers.mp4" type="video/mp4" />
                Your browser does not support the video tag.
              </video>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <CtaSection
      title="Ready to Get Started?"
      subtitle="Join thousands of music teachers and students using Practice Buddy."
      primaryHref="/"
      primaryLabel="Sign Up for Free"
      secondaryHref="/contact"
      secondaryLabel="Contact Us"
      fullWidth={true}
    />
  </div>
  <div id="footer"></div>
  <script>
    import { createApp } from "vue";
    import Footer from "../components/Footer.vue";
    createApp(Footer).mount("#footer");
  </script>
</Layout>
