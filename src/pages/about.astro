---
import Layout from "../components/Layout.astro";
---

<Layout title="About Practice Buddy - Music Practice Made Simple">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-primary to-musical-purple"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
        <div class="text-center">
         
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
            About <span class="text-musical-secondary">Practice Buddy</span>
          </h1>
          <p
            class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed"
          >
            Revolutionizing music education through smart practice tracking,
            personalized goals, and seamless teacher-student collaboration.
          </p>
        </div>
      </div>
    </div>

    <!-- Mission Section -->
    <div class="py-16">
      <div class="container max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-musical-graphite mb-6">
            Our Mission
          </h2>
          <p class="text-lg text-musical-graphite/80 max-w-4xl mx-auto">
            Practice Buddy was created to bridge the gap between music lessons
            and home practice. We believe that consistent, focused practice is
            the key to musical growth, and we're here to make that journey
            engaging, trackable, and rewarding.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="card text-center">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2zm0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Track Progress
            </h3>
            <p class="text-musical-graphite/70">
              Monitor practice sessions, track goals, and visualize musical
              growth over time.
            </p>
          </div>

          <div class="card text-center">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-secondary to-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-yellow-600"
            >
              <svg
                class="w-8 h-8 text-musical-graphite"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Personalized Learning
            </h3>
            <p class="text-musical-graphite/70">
              Custom assignments and goals tailored to each student's skill
              level and interests.
            </p>
          </div>

          <div class="card text-center">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-purple to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-purple-600"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Teacher Collaboration
            </h3>
            <p class="text-musical-graphite/70">
              Seamless communication between teachers and students for better
              learning outcomes.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Features Section -->
    <div class="py-16 bg-white">
      <div class="container max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-musical-graphite mb-6">
            Why Choose Practice Buddy?
          </h2>
          <p class="text-lg text-musical-graphite/80 max-w-3xl mx-auto">
            Built specifically for music education, our platform combines
            powerful features with an intuitive interface.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="card">
            <h3 class="text-2xl font-bold text-musical-graphite mb-6">
              For Music Teachers
            </h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-primary rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Create and manage multiple classes with ease</span
                >
              </li>
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-primary rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Assign personalized practice goals and track progress</span
                >
              </li>
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-primary rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Monitor student engagement and provide feedback</span
                >
              </li>
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-primary rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Generate comprehensive reports and insights</span
                >
              </li>
            </ul>
          </div>

          <div class="card">
            <h3 class="text-2xl font-bold text-musical-graphite mb-6">
              For Students
            </h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Set and achieve personalized practice goals</span
                >
              </li>
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Track practice sessions and celebrate milestones</span
                >
              </li>
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Receive feedback and encouragement from teachers</span
                >
              </li>
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 shadow-[0_2px_0_rgba(0,0,0,0.1)]"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Build consistent practice habits for lasting success</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- How It Works Section -->
    <div class="py-16">
      <div class="container max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-musical-graphite mb-6">
            How It Works
          </h2>
          <p class="text-lg text-musical-graphite/80 max-w-3xl mx-auto">
            Getting started with Practice Buddy is simple and straightforward.
          </p>
        </div>

        <div class="grid md:grid-cols-4 gap-8">
          <div class="card text-center">
            <div
              class="w-20 h-20 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
            >
              1
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Sign Up
            </h3>
            <p class="text-musical-graphite/70">
              Teachers and students create accounts to get started with the
              platform.
            </p>
          </div>

          <div class="card text-center">
            <div
              class="w-20 h-20 bg-gradient-to-br from-musical-secondary to-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 text-musical-graphite text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-yellow-600"
            >
              2
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Set Up Classes
            </h3>
            <p class="text-musical-graphite/70">
              Teachers create classes and invite students to join their musical
              community.
            </p>
          </div>

          <div class="card text-center">
            <div
              class="w-20 h-20 bg-gradient-to-br from-musical-purple to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-purple-600"
            >
              3
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Create Goals
            </h3>
            <p class="text-musical-graphite/70">
              Set personalized practice goals and assignments for each student.
            </p>
          </div>

          <div class="card text-center">
            <div
              class="w-20 h-20 bg-gradient-to-br from-musical-coral to-orange-400 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-bold shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-orange-600"
            >
              4
            </div>
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Track Progress
            </h3>
            <p class="text-musical-graphite/70">
              Monitor practice sessions and celebrate achievements together.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="py-16 bg-gradient-to-r from-musical-primary to-musical-purple">
      <div class="container max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Ready to Transform Your Music Teaching?
        </h2>
        <p class="text-xl text-white/90 mb-8">
          Join thousands of music teachers who are already using Practice Buddy
          to inspire their students and streamline their teaching.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn btn-primary"> Get Started Today </a>
          <a
            href="/"
            class="btn btn-outline text-white border-white hover:bg-white hover:text-musical-primary"
          >
            Learn More
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
