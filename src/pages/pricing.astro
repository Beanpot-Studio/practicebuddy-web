---
import Layout from "../components/Layout.astro";
import CtaSection from "../components/CtaSection.astro";
import Footer from "../components/Footer.vue";
// Stripe Pricing Table environment variables (must be prefixed with PUBLIC_ to be exposed to the client)
const publishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY;
const pricingTableId = import.meta.env.PUBLIC_STRIPE_PRICING_TABLE_ID;
const proPriceId = import.meta.env.PUBLIC_STRIPE_PRO_PRICE_ID;
const studioPriceId = import.meta.env.PUBLIC_STRIPE_STUDIO_PRICE_ID;
const proAnnualPriceId = import.meta.env.PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID;
const studioAnnualPriceId = import.meta.env.PUBLIC_STRIPE_STUDIO_ANNUAL_PRICE_ID;
---

<Layout title="Pricing - Practice Buddy">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-success to-green-400"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-32 pb-10 md:pb-16">
        <div class="text-center">
          <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold text-white mb-4 md:mb-6">
            Simple, <span class="text-musical-graphite">Transparent</span> Pricing
          </h1>
          <p
            class="text-base sm:text-lg md:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed px-2"
          >
            Practice Buddy is always free for students. Teachers, School
            Districts, and Parents can choose the perfect plan for your music
            studio or program. Start free, upgrade when you're ready.
          </p>
        </div>
      </div>
    </div>

    <!-- Plan Comparison -->
    <div class="py-10 md:py-16">
      <div class="container max-w-6xl mx-auto px-4">
        <div class="text-center mb-8 md:mb-12">
          <h2 class="text-2xl sm:text-3xl font-bold text-musical-graphite mb-3 md:mb-4">
            Simple, Student-Based Pricing
          </h2>
          <p class="text-base md:text-lg text-musical-graphite/80">
            Pay only for the number of students you teach. Classes are unlimited
            on all plans. Secure checkout handled by Stripe. Free for up to 5 students.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 mb-8 md:mb-12">
          <!-- Pro Plan -->
          <div class="bg-white rounded-2xl md:rounded-3xl p-5 md:p-8 shadow-lg border-2 border-blue-500">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-xl md:text-2xl font-bold text-musical-graphite">Pro</h3>
              <span class="px-2 py-1 text-xs font-semibold bg-blue-500 text-white rounded-full">Most Popular</span>
            </div>
            <p class="text-musical-graphite/70 mb-4">For growing music studios (6-10 students)</p>

            <!-- Toggle -->
            <div class="inline-flex bg-blue-50 border-2 border-blue-200 rounded-xl overflow-hidden mb-4">
              <button id="pro-toggle-monthly" class="px-4 py-2 text-sm font-semibold text-blue-700 bg-white">Monthly</button>
              <button id="pro-toggle-annual" class="px-4 py-2 text-sm font-semibold text-blue-700/70">Annual</button>
            </div>

            <!-- Prices -->
            <div>
              <div id="pro-price-monthly" class="text-4xl font-bold text-musical-graphite">$9.99<span class="text-base font-medium text-gray-500">/mo</span></div>
              <div id="pro-price-annual" class="hidden text-4xl font-bold text-musical-graphite">$100.00<span class="text-base font-medium text-gray-500">/yr</span></div>
            </div>

            <button id="upgrade-pro" class="btn btn-primary w-full mt-4" data-monthly-id={proPriceId || ''} data-annual-id={proAnnualPriceId || ''}>
              Upgrade
            </button>

           
          </div>

          <!-- Studio Plan -->
          <div class="bg-white rounded-2xl md:rounded-3xl p-5 md:p-8 shadow-lg border-2 border-purple-500">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-xl md:text-2xl font-bold text-musical-graphite">Studio</h3>
            </div>
            <p class="text-musical-graphite/70 mb-4">For large studios & schools (unlimited students)</p>

            <!-- Toggle -->
            <div class="inline-flex bg-purple-50 border-2 border-purple-200 rounded-xl overflow-hidden mb-4">
              <button id="studio-toggle-monthly" class="px-4 py-2 text-sm font-semibold text-purple-700 bg-white">Monthly</button>
              <button id="studio-toggle-annual" class="px-4 py-2 text-sm font-semibold text-purple-700/70">Annual</button>
            </div>

            <!-- Prices -->
            <div>
              <div id="studio-price-monthly" class="text-4xl font-bold text-musical-graphite">$24.99<span class="text-base font-medium text-gray-500">/mo</span></div>
              <div id="studio-price-annual" class="hidden text-4xl font-bold text-musical-graphite">$240.00<span class="text-base font-medium text-gray-500">/yr</span></div>
            </div>

            <button id="upgrade-studio" class="btn btn-purple w-full mt-4" data-monthly-id={studioPriceId || ''} data-annual-id={studioAnnualPriceId || ''}>
              Upgrade
            </button>

          
          </div>
        </div>

       
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="py-10 md:py-16 bg-white">
      <div class="container max-w-4xl mx-auto px-4">
        <div class="text-center mb-10 md:mb-16">
          <h2 class="text-2xl sm:text-3xl font-bold text-musical-graphite mb-4 md:mb-6">
            Frequently Asked Questions
          </h2>
          <p class="text-base md:text-lg text-musical-graphite/80">
            Everything you need to know about our pricing.
          </p>
        </div>

        <div class="space-y-4 md:space-y-6">
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Can I change plans anytime?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! You can upgrade or downgrade your plan at any time. 
            </p>
          </div>
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              How is student enrollment calculated?
            </h3>
            <p class="text-musical-graphite/70">
              We calculate the number of students based on the number of
              students you teach per class. If the same student is enrolled in
              multiple classes, we count each enrollment as a student.
            </p>
          </div>
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              What payment methods do you accept?
            </h3>
            <p class="text-musical-graphite/70">
              We accept all major credit cards. Secure checkout handled by Stripe.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Do you offer discounts for annual billing?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! Annual plans come with a 20% discount compared to monthly
              billing.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <CtaSection
      title="Ready to Get Started?"
      subtitle="Join thousands of music teachers who are already using Practice Buddy."
      primaryHref="/"
      primaryLabel="Sign up for Free"
      fullWidth={true}
    />
  </div>
  <Footer client:load />
  <script type="module">
    import { handleSubscriptionUpgrade } from "/src/lib/stripe.js";
    // Toggle logic
    const proMonthly = document.getElementById('pro-toggle-monthly');
    const proAnnual = document.getElementById('pro-toggle-annual');
    const proPriceMonthly = document.getElementById('pro-price-monthly');
    const proPriceAnnual = document.getElementById('pro-price-annual');
    const proUpgrade = document.getElementById('upgrade-pro');
    function setPro(mode){
      if(mode==='annual'){
        proPriceMonthly?.classList.add('hidden');
        proPriceAnnual?.classList.remove('hidden');
        proMonthly?.classList.remove('bg-white');
        proMonthly?.classList.add('text-blue-700/70');
        proAnnual?.classList.add('bg-white');
        proAnnual?.classList.remove('text-blue-700/70');
        const annualId = proUpgrade?.getAttribute('data-annual-id') || '';
        if (annualId) proUpgrade?.setAttribute('data-price-id', annualId);
      } else {
        proPriceAnnual?.classList.add('hidden');
        proPriceMonthly?.classList.remove('hidden');
        proAnnual?.classList.remove('bg-white');
        proAnnual?.classList.add('text-blue-700/70');
        proMonthly?.classList.add('bg-white');
        proMonthly?.classList.remove('text-blue-700/70');
        const monthlyId = proUpgrade?.getAttribute('data-monthly-id') || '';
        if (monthlyId) proUpgrade?.setAttribute('data-price-id', monthlyId);
      }
    }
    proMonthly?.addEventListener('click', ()=>setPro('monthly'));
    proAnnual?.addEventListener('click', ()=>setPro('annual'));
    setPro('monthly');

    const studioMonthly = document.getElementById('studio-toggle-monthly');
    const studioAnnual = document.getElementById('studio-toggle-annual');
    const studioPriceMonthly = document.getElementById('studio-price-monthly');
    const studioPriceAnnual = document.getElementById('studio-price-annual');
    const studioUpgrade = document.getElementById('upgrade-studio');
    function setStudio(mode){
      if(mode==='annual'){
        studioPriceMonthly?.classList.add('hidden');
        studioPriceAnnual?.classList.remove('hidden');
        studioMonthly?.classList.remove('bg-white');
        studioMonthly?.classList.add('text-purple-700/70');
        studioAnnual?.classList.add('bg-white');
        studioAnnual?.classList.remove('text-purple-700/70');
        const annualId = studioUpgrade?.getAttribute('data-annual-id') || '';
        if (annualId) studioUpgrade?.setAttribute('data-price-id', annualId);
      } else {
        studioPriceAnnual?.classList.add('hidden');
        studioPriceMonthly?.classList.remove('hidden');
        studioAnnual?.classList.remove('bg-white');
        studioAnnual?.classList.add('text-purple-700/70');
        studioMonthly?.classList.add('bg-white');
        studioMonthly?.classList.remove('text-purple-700/70');
        const monthlyId = studioUpgrade?.getAttribute('data-monthly-id') || '';
        if (monthlyId) studioUpgrade?.setAttribute('data-price-id', monthlyId);
      }
    }
    studioMonthly?.addEventListener('click', ()=>setStudio('monthly'));
    studioAnnual?.addEventListener('click', ()=>setStudio('annual'));
    setStudio('monthly');

    // Upgrade button wiring
    function wire(btnId) {
      const btn = document.getElementById(btnId);
      if (!btn) return;
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-price-id") || "";
        console.log("Clicked:", btnId, "priceId:", id);
        if (!id || !id.startsWith("price_")) {
          alert("Plan is not available. Check PUBLIC_STRIPE_*_PRICE_ID.");
          return;
        }
        try {
          await handleSubscriptionUpgrade(id);
        } catch (e) {
          console.error("Upgrade failed", e);
        }
      });
    }
    wire('upgrade-pro');
    wire('upgrade-studio');
  </script>
</Layout>
