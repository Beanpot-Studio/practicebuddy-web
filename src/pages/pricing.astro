            <a href="/" class="btn btn-primary w-full">Start Pro Trial</a>
          </div>

          <!-- Studio Plan -->
          <div class="card text-center">
            <div class="mb-6">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">
                Studio
              </h3>
              <p class="text-musical-graphite/70">For large music schools</p>
            </div>

            <div class="mb-8">
