---
import Layout from "../components/Layout.astro";
import CtaSection from "../components/CtaSection.astro";
---

<Layout title="Pricing - Practice Buddy">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-success to-green-400"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
        <div class="text-center">
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
            Simple, <span class="text-musical-graphite">Transparent</span> Pricing
          </h1>
          <p
            class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed"
          >
            Practice Buddy is always free for students. Teachers, School
            Districts, and Parents can choose the perfect plan for your music
            studio or program. Start free, upgrade when you're ready.
          </p>
        </div>
      </div>
    </div>

    <!-- Pricing Plans -->
    <div class="py-16">
      <div class="container max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-3 gap-8">
          <!-- Free Plan -->
          <div class="card text-center">
            <div class="mb-6">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">
                Free
              </h3>
              <p class="text-musical-graphite/70">
                For up to five students.Perfect for getting started
              </p>
            </div>

            <div class="mb-8">
              <div class="text-4xl font-bold text-musical-graphite mb-2">
                $0
              </div>
              <p class="text-musical-graphite/70">Forever free</p>
            </div>

            <a href="/" class="btn btn-outline w-full">Get Started Free</a>
          </div>

          <!-- Pro Plan -->
          <div
            class="card text-center border-4 border-musical-primary relative"
          >
            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
              <span
                class="bg-musical-primary text-white px-4 py-2 rounded-full text-sm font-semibold"
                >Most Popular</span
              >
            </div>

            <div class="mb-6">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">Pro</h3>
              <p class="text-musical-graphite/70">
                For up to 10 students. Perfect for growing studios
              </p>
            </div>

            <div class="mb-8">
              <div class="text-4xl font-bold text-musical-graphite mb-2">
                $9.99
              </div>
              <p class="text-musical-graphite/70">per month or $100/year</p>
            </div>

            <a href="/" class="btn btn-primary w-full">Purchase Pro</a>
          </div>

          <!-- Studio Plan -->
          <div class="card text-center">
            <div class="mb-6">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">
                Studio
              </h3>
              <p class="text-musical-graphite/70">
                For 10+ students. Great for larger music schools or programs.
              </p>
            </div>

            <div class="mb-8">
              <div class="text-4xl font-bold text-musical-graphite mb-2">
                $24.99
              </div>
              <p class="text-musical-graphite/70">per month or $200/year</p>
            </div>

            <a
              href="/"
              class="btn bg-musical-coral text-white btn-outline w-full"
              >Purchase Studio Plan</a
            >
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="py-16 bg-white">
      <div class="container max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-musical-graphite mb-6">
            Frequently Asked Questions
          </h2>
          <p class="text-lg text-musical-graphite/80">
            Everything you need to know about our pricing.
          </p>
        </div>

        <div class="space-y-6">
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Can I change plans anytime?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! You can upgrade or downgrade your plan at any time. Changes
              take effect immediately.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Is there a setup fee?
            </h3>
            <p class="text-musical-graphite/70">
              No setup fees! All plans include a 14-day free trial to get you
              started.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              What payment methods do you accept?
            </h3>
            <p class="text-musical-graphite/70">
              We accept all major credit cards, PayPal, and bank transfers for
              annual plans.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Do you offer discounts for annual billing?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! Annual plans come with a 20% discount compared to monthly
              billing.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <CtaSection
      title="Ready to Get Started?"
      subtitle="Join thousands of music teachers who are already using Practice Buddy."
      primaryHref="/"
      primaryLabel="Sign Up for Free"
      secondaryHref="/contact"
      secondaryLabel="Contact Sales"
      fullWidth={true}
    />
  </div>
  <div id="footer"></div>
  <script>
    import { createApp } from "vue";
    import Footer from "../components/Footer.vue";
    createApp(Footer).mount("#footer");
  </script>
</Layout>
