    <!-- FAQ Section -->
    <div class="py-16 bg-white">
      <div class="container max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-musical-graphite mb-6">
            Frequently Asked Questions
          </h2>
          <p class="text-lg text-musical-graphite/80">
            Everything you need to know about our pricing.
          </p>
        </div>

        <div class="space-y-6">
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Can I change plans anytime?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! You can upgrade or downgrade your plan at any time. Changes
              take effect immediately.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Is there a setup fee?
            </h3>
            <p class="text-musical-graphite/70">
              No setup fees! All plans include a 14-day free trial to get you
              started.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              What payment methods do you accept?
            </h3>
            <p class="text-musical-graphite/70">
              We accept all major credit cards, PayPal, and bank transfers for
              annual plans.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Do you offer discounts for annual billing?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! Annual plans come with a 20% discount compared to monthly
              billing.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="py-16 bg-gradient-to-r from-musical-primary to-musical-purple">
      <div class="container max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Ready to Get Started?
        </h2>
        <p class="text-xl text-white/90 mb-8">
          Join thousands of music teachers who are already using Practice Buddy.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn btn-primary">Start Free Trial</a>
          <a
            href="/contact"
            class="btn btn-outline text-white border-white hover:bg-white hover:text-musical-primary"
          >
            Contact Sales
