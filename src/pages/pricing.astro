---
import Layout from "../components/Layout.astro";
---

<Layout title="Pricing - Practice Buddy">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-success to-green-400"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
        <div class="text-center">
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
            Simple, <span class="text-musical-graphite">Transparent</span> Pricing
          </h1>
          <p
            class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed"
          >
            Choose the perfect plan for your music studio. Start free, upgrade
            when you're ready.
          </p>
        </div>
      </div>
    </div>

    <!-- Pricing Plans -->
    <div class="py-16">
      <div class="container max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-3 gap-8">
          <!-- Free Plan -->
          <div class="card text-center">
            <div class="mb-6">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">
                Free
              </h3>
              <p class="text-musical-graphite/70">
                Perfect for getting started
              </p>
            </div>

            <div class="mb-8">
              <div class="text-4xl font-bold text-musical-graphite mb-2">
                $0
              </div>
              <p class="text-musical-graphite/70">Forever free</p>
            </div>

            <ul class="space-y-4 mb-8 text-left">
              <li class="flex items-center gap-3">
                <div
                  class="w-5 h-5 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0"
                >
                  <svg
                    class="w-3 h-3 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80">Up to 5 students</span>
              </li>
              <li class="flex items-center gap-3">
                <div
                  class="w-5 h-5 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0"
                >
                  <svg
                    class="w-3 h-3 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80"
                  >Basic practice tracking</span
                >
              </li>
              <li class="flex items-center gap-3">
                <div
                  class="w-5 h-5 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0"
                >
                  <svg
                    class="w-3 h-3 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80">Simple goal setting</span
                >
              </li>
              <li class="flex items-center gap-3">
                <div
                  class="w-5 h-5 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0"
                >
                  <svg
                    class="w-3 h-3 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-musical-graphite/80">Email support</span>
              </li>
            </ul>

            <a href="/" class="btn btn-outline w-full">Get Started Free</a>
          </div>

          <!-- Pro Plan -->
          <div
            class="card text-center border-4 border-musical-primary relative"
          >
            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
              <span
                class="bg-musical-primary text-white px-4 py-2 rounded-full text-sm font-semibold"
                >Most Popular</span
              >
            </div>

            <div class="mb-6">
              <h3 class="text-2xl font-bold text-musical-graphite mb-2">Pro</h3>
              <p class="text-musical-graphite/70">
                Perfect for growing studios
              </p>
            </div>

            <div class="mb-8">
              <div class="text-4xl font-bold text-musical-graphite mb-2">
                $9.99
              </div>
              <p class="text-musical-graphite/70">per month</p>
            </div>

            <ul class="space-y-4 mb-8 text-left">
              <li class="flex items-center gap-3">
                <div
                  class="w-5 h-5 bg-musical-success rounded-full flex items-center justify-center flex-shrink-0"
