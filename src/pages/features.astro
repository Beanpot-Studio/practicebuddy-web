---
import Layout from "../components/Layout.astro";
---

<Layout title="Features - Practice Buddy">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-secondary to-yellow-400"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
        <div class="text-center">
          <h1 class="text-4xl md:text-6xl font-bold text-musical-graphite mb-6">
            Powerful <span class="text-white">Features</span>
          </h1>
          <p
            class="text-xl md:text-2xl text-musical-graphite/90 max-w-3xl mx-auto leading-relaxed"
          >
            Everything you need to make music practice engaging, trackable, and
            rewarding.
          </p>
        </div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="py-16">
      <div class="container max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Practice Tracking -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Practice Tracking
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Track practice sessions, set goals, and monitor progress over
              time.
            </p>
          </div>

          <!-- Goal Setting -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-success to-green-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-green-600"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Goal Setting
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Create personalized practice goals and celebrate achievements.
            </p>
          </div>

          <!-- Teacher Dashboard -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-purple to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-purple-600"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2zm0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Teacher Dashboard
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Manage classes, assignments, and student progress all in one
              place.
            </p>
          </div>

          <!-- Student Portal -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-coral to-orange-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-orange-600"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Student Portal
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Access assignments, track progress, and stay motivated with
              rewards.
            </p>
          </div>

          <!-- Progress Analytics -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2zm0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Progress Analytics
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Visualize progress with charts and detailed reports.
            </p>
          </div>

          <!-- Mobile App -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-secondary to-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-yellow-600"
            >
              <svg
                class="w-8 h-8 text-musical-graphite"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Mobile App
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Practice anywhere with our mobile-friendly interface.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="py-16 bg-gradient-to-r from-musical-primary to-musical-purple">
      <div class="container max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Ready to Get Started?
        </h2>
        <p class="text-xl text-white/90 mb-8">
          Join thousands of music teachers and students using Practice Buddy.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn btn-primary">Start Free Trial</a>
          <a
            href="/contact"
            class="btn btn-outline text-white border-white hover:bg-white hover:text-musical-primary"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
