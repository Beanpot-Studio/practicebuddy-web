---
import Layout from "../components/Layout.astro";
import CtaSection from "../components/CtaSection.astro";
---

<Layout title="Features - Practice Buddy">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-secondary to-yellow-400"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-32 pb-10 md:pb-16">
        <div class="text-center">
          <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold text-musical-graphite mb-4 md:mb-6">
            Powerful <span class="text-white">Features</span>
          </h1>
          <p
            class="text-lg md:text-xl lg:text-2xl text-musical-graphite/90 max-w-3xl mx-auto leading-relaxed px-2"
          >
            Everything you need to make music practice engaging, trackable, and
            rewarding.
          </p>
        </div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="py-10 md:py-16">
      <div class="container max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8">
          <!-- Practice Tracking -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
            >
              <svg
                class="w-8 h-8 text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Practice Tracking
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Track practice sessions, set goals, and monitor progress over
              time.
            </p>
          </div>

          <!-- Goal Setting -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-success to-green-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-green-600"
            >
              <svg
                class="w-8 h-8 text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Goal Setting
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Create personalized practice goals and celebrate achievements.
            </p>
          </div>

          <!-- Teacher Dashboard -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-purple to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-purple-600"
            >
              <svg
                class="w-8 h-8 text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <rect x="3" y="10" width="4" height="10" rx="1"></rect>
                <rect x="10" y="6" width="4" height="14" rx="1"></rect>
                <rect x="17" y="2" width="4" height="18" rx="1"></rect>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Teacher Dashboard
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Manage classes, assignments, and student progress all in one
              place.
            </p>
          </div>

          <!-- Student Portal -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-coral to-orange-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-orange-600"
            >
              <svg
                class="w-8 h-8 text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="7" r="4"></circle>
                <path d="M6 21v-2a6 6 0 0 1 12 0v2"></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Student Portal
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Access assignments, track progress, and stay motivated with
              rewards.
            </p>
          </div>

          <!-- Progress Analytics -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
            >
              <svg
                class="w-8 h-8 text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Progress Analytics
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Visualize progress with charts and detailed reports.
            </p>
          </div>

          <!-- Assess Progress -->
          <div class="card">
            <div
              class="w-16 h-16 bg-gradient-to-br from-musical-secondary to-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-yellow-600"
            >
              <svg
                class="w-8 h-8 text-musical-graphite"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
                <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3"></path>
                <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3"></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold text-musical-graphite mb-2 text-center"
            >
              Assess Progress
            </h3>
            <p class="text-musical-graphite/70 text-center">
              Teachers can listen to student practice sessions and provide
              stickers and notes.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <!-- Student Performances -->
    <div class="py-10 md:py-16 bg-musical-cream">
      <div class="container max-w-7xl mx-auto px-4">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-bold text-musical-graphite mb-6 md:mb-8 text-center"
        >
          Featured Practices: Hear Our Students
        </h2>
        <p class="text-musical-graphite/80 text-center mb-6 md:mb-10 text-sm md:text-base">
          A few recent Practice Buddy practice sessions.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
          <!-- Card 1 -->
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Jazz Piano
            </h3>

            <audio controls class="w-full">
              <source
                src="https://res.cloudinary.com/front-end-foxes/video/upload/v1754877175/practice-buddy/high-end-jazz_egh7x6.m4a"
                type="audio/mpeg"
              />
              Your browser does not support the audio element.
            </audio>
          </div>
          <!-- Card 2 -->
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Classical Piano
            </h3>

            <audio controls class="w-full">
              <source
                src="https://res.cloudinary.com/front-end-foxes/video/upload/v1754877174/practice-buddy/good_p8jltg.m4a"
                type="audio/mpeg"
              />
              Your browser does not support the audio element.
            </audio>
          </div>

          <!-- Card 3 -->
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              1-2-3-4 Let's Go!
            </h3>

            <audio controls class="w-full">
              <source
                src="https://res.cloudinary.com/front-end-foxes/video/upload/v1754877174/practice-buddy/1-2-3-4_cheltd.m4a"
                type="audio/mpeg"
              />
            </audio>
          </div>
          <!-- Card 4 -->
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-2">
              Ragtime Piano
            </h3>

            <audio controls class="w-full">
              <source
                src="https://res.cloudinary.com/front-end-foxes/video/upload/v1754877176/practice-buddy/jazz_r1r9uw.m4a"
                type="audio/mpeg"
              />
            </audio>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <CtaSection
      title="Ready to Get Started?"
      subtitle="Join thousands of music teachers and students using Practice Buddy."
      primaryHref="/"
      primaryLabel="Sign Up for Free"
      secondaryHref="/contact"
      secondaryLabel="Contact Us"
      fullWidth={true}
    />
  </div>
  <div id="footer"></div>
  <script>
    import { createApp } from "vue";
    import Footer from "../components/Footer.vue";
    createApp(Footer).mount("#footer");
  </script>
</Layout>
