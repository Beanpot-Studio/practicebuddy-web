---
import Layout from "../components/Layout.astro";
---

<Layout title="Contact Us - Practice Buddy">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-coral to-orange-400"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
        <div class="text-center">
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
            Get in <span class="text-musical-graphite">Touch</span>
          </h1>
          <p
            class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed"
          >
            Have questions? We'd love to hear from you. Send us a message and
            we'll respond as soon as possible.
          </p>
        </div>
      </div>
    </div>

    <!-- Contact Form Section -->
    <div class="py-16">
      <div class="container max-w-4xl mx-auto">
        <div class="grid lg:grid-cols-1 gap-12">
         

          <!-- Contact Form -->
          <div class="card">
            <h3 class="text-2xl font-bold text-musical-graphite mb-6">
              Send us a Message
            </h3>
            <form
              class="space-y-6"
              action="https://formspree.io/f/xyzplnry"
              method="POST"
            >
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label
                    for="firstName"
                    class="block text-sm font-medium text-musical-graphite mb-2"
                    >First Name</label
                  >
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                    required
                  />
                </div>
                <div>
                  <label
                    for="lastName"
                    class="block text-sm font-medium text-musical-graphite mb-2"
                    >Last Name</label
                  >
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                    required
                  />
                </div>
              </div>

              <div>
                <label
                  for="email"
                  class="block text-sm font-medium text-musical-graphite mb-2"
                  >Email</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                  required
                />
              </div>

              <div>
                <label
                  for="subject"
                  class="block text-sm font-medium text-musical-graphite mb-2"
                  >Subject</label
                >
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                  required
                >
                  <option value="">Select a subject</option>
                  <option value="general">General Inquiry</option>
                  <option value="support">Technical Support</option>
                  <option value="billing">Billing Question</option>
                  <option value="partnership">Partnership Opportunity</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label
                  for="message"
                  class="block text-sm font-medium text-musical-graphite mb-2"
                  >Message</label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors resize-none"
                  required></textarea>
              </div>

              <button type="submit" class="btn btn-primary w-full">
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="py-16 bg-white">
      <div class="container max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-musical-graphite mb-6">
            Frequently Asked Questions
          </h2>
          <p class="text-lg text-musical-graphite/80">
            Find answers to common questions about Practice Buddy.
          </p>
        </div>

        <div class="space-y-6">
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              How much does Practice Buddy cost?
            </h3>
            <p class="text-musical-graphite/70">
              We offer flexible pricing plans starting at $9.99/month for
              teachers. Students can join for free when invited by their
              teacher.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Can I try Practice Buddy before subscribing?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! We offer a 14-day free trial with full access to all
              features. No credit card required to start.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Is Practice Buddy suitable for all instruments?
            </h3>
            <p class="text-musical-graphite/70">
              Absolutely! Practice Buddy works with any instrument or voice. Our
              goal-setting and tracking features are universal.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              How do I get my students started?
            </h3>
            <p class="text-musical-graphite/70">
              Simply create a class and send invitation links to your students.
              They can join with just an email address.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div id="footer"></div>
  <script>
    import { createApp } from "vue";
    import Footer from "../components/Footer.vue";
    createApp(Footer).mount("#footer");
  </script>
</Layout>
