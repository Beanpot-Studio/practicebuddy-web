---
import Layout from "../components/Layout.astro";
---

<Layout title="Contact Us - Practice Buddy">
  <div class="min-h-screen bg-musical-cream">
    <!-- Hero Section -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-musical-coral to-orange-400"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
        <div class="text-center">
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
            Get in <span class="text-musical-graphite">Touch</span>
          </h1>
          <p
            class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed"
          >
            Have questions? We'd love to hear from you. Send us a message and
            we'll respond as soon as possible.
          </p>
        </div>
      </div>
    </div>

    <!-- Contact Form Section -->
    <div class="py-16">
      <div class="container max-w-4xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Contact Information -->
          <div>
            <h2 class="text-3xl font-bold text-musical-graphite mb-6">
              Let's Talk
            </h2>
            <p class="text-lg text-musical-graphite/80 mb-8">
              Ready to transform your music teaching? We're here to help you get
              started with Practice Buddy.
            </p>

            <div class="space-y-6">
              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 bg-gradient-to-br from-musical-primary to-blue-400 rounded-full flex items-center justify-center shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-blue-600"
                >
                  <svg
                    class="w-6 h-6 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-musical-graphite">Email</h3>
                  <p class="text-musical-graphite/70">
                    practicebuddy@beanpotstudio.com
                  </p>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 bg-gradient-to-br from-musical-success to-green-400 rounded-full flex items-center justify-center shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-green-600"
                >
                  <svg
                    class="w-6 h-6 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-musical-graphite">Phone</h3>
                  <p class="text-musical-graphite/70">+1 (555) 123-4567</p>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 bg-gradient-to-br from-musical-purple to-purple-600 rounded-full flex items-center justify-center shadow-[0_4px_0_rgba(0,0,0,0.1)] border-2 border-purple-600"
                >
                  <svg
                    class="w-6 h-6 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-musical-graphite">Office</h3>
                  <p class="text-musical-graphite/70">
                    123 Music Street<br />Melody City, MC 12345
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="card">
            <h3 class="text-2xl font-bold text-musical-graphite mb-6">
              Send us a Message
            </h3>
            <form
              class="space-y-6"
              action="https://formspree.io/f/xyzplnry"
              method="POST"
            >
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label
                    for="firstName"
                    class="block text-sm font-medium text-musical-graphite mb-2"
                    >First Name</label
                  >
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                    required
                  />
                </div>
                <div>
                  <label
                    for="lastName"
                    class="block text-sm font-medium text-musical-graphite mb-2"
                    >Last Name</label
                  >
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                    required
                  />
                </div>
              </div>

              <div>
                <label
                  for="email"
                  class="block text-sm font-medium text-musical-graphite mb-2"
                  >Email</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                  required
                />
              </div>

              <div>
                <label
                  for="subject"
                  class="block text-sm font-medium text-musical-graphite mb-2"
                  >Subject</label
                >
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors"
                  required
                >
                  <option value="">Select a subject</option>
                  <option value="general">General Inquiry</option>
                  <option value="support">Technical Support</option>
                  <option value="billing">Billing Question</option>
                  <option value="partnership">Partnership Opportunity</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label
                  for="message"
                  class="block text-sm font-medium text-musical-graphite mb-2"
                  >Message</label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-musical-primary focus:outline-none transition-colors resize-none"
                  required></textarea>
              </div>

              <button type="submit" class="btn btn-primary w-full">
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="py-16 bg-white">
      <div class="container max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-musical-graphite mb-6">
            Frequently Asked Questions
          </h2>
          <p class="text-lg text-musical-graphite/80">
            Find answers to common questions about Practice Buddy.
          </p>
        </div>

        <div class="space-y-6">
          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              How much does Practice Buddy cost?
            </h3>
            <p class="text-musical-graphite/70">
              We offer flexible pricing plans starting at $9.99/month for
              teachers. Students can join for free when invited by their
              teacher.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Can I try Practice Buddy before subscribing?
            </h3>
            <p class="text-musical-graphite/70">
              Yes! We offer a 14-day free trial with full access to all
              features. No credit card required to start.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              Is Practice Buddy suitable for all instruments?
            </h3>
            <p class="text-musical-graphite/70">
              Absolutely! Practice Buddy works with any instrument or voice. Our
              goal-setting and tracking features are universal.
            </p>
          </div>

          <div class="card">
            <h3 class="text-xl font-semibold text-musical-graphite mb-3">
              How do I get my students started?
            </h3>
            <p class="text-musical-graphite/70">
              Simply create a class and send invitation links to your students.
              They can join with just an email address.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
