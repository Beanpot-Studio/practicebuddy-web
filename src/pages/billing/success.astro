---
import Layout from "../../components/Layout.astro";
---

<Layout title="Billing Success">
  <div class="min-h-screen bg-musical-cream">
    <div class="container max-w-xl mx-auto py-24 px-4 text-center">
      <div class="bg-white rounded-3xl p-10 shadow-lg border-2 border-green-200">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
          <span class="text-2xl">✅</span>
        </div>
        <h1 class="text-3xl font-bold text-musical-graphite mb-2">Subscription Activated</h1>
        <p class="text-musical-graphite/70 mb-6">Thanks for upgrading! You can now add more students.</p>
        <a href="/dashboard" class="btn btn-primary w-full">Go to Dashboard</a>
        <script type="module">
          try {
            const params = new URLSearchParams(location.search)
            const priceId = params.get('price')
            if (priceId) {
              sessionStorage.setItem('pb_checkout_price', priceId)
            }
            sessionStorage.setItem('pb_show_thanks', '1')
          } catch {}
        </script>
      </div>
    </div>
  </div>
</Layout>


